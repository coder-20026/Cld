<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_gps"
                android:tint="@color/primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Coordinates Found"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/on_surface" />

            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:tint="@color/on_surface_variant"
                android:background="@drawable/bg_icon_container"
                android:contentDescription="Close" />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/outline_variant"
            android:layout_marginBottom="14dp" />

        <!-- Raw OCR Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAW OCR TEXT"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/on_surface_variant"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRawText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_code_block"
            android:padding="10dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="monospace"
            android:maxLines="3"
            android:ellipsize="end"
            tools:text="Mar 28, 2026 10:36am 22.1234N 71.1234E Borsad Gujarat"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Matched Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MATCHED PATTERN"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/on_surface_variant"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvMatchedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_code_block"
            android:padding="10dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/tertiary"
            android:fontFamily="monospace"
            tools:text="22.1234N 71.1234E"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Final Coordinates -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FINAL COORDINATES"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/on_surface_variant"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_container">

            <TextView
                android:id="@+id/tvCoordinates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textColor="@color/on_primary_container"
                android:fontFamily="monospace"
                android:gravity="center"
                tools:text="22.1234,71.1234"
                xmlns:tools="http://schemas.android.com/tools" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCopy"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Copy"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_copy"
                app:iconGravity="textStart"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMaps"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Open Maps"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_map"
                app:iconGravity="textStart" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
